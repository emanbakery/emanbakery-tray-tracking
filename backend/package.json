{\n  \"name\": \"eman-bakery-backend\",\n  \"version\": \"1.0.0\",\n  \"description\": \"Express.js backend for Eman Bakery Tray Tracking\",\n  \"private\": true,\n  \"type\": \"module\",\n  \"main\": \"dist/server.js\",\n  \"scripts\": {\n    \"dev\": \"nodemon --exec ts-node src/server.ts\",\n    \"build\": \"tsc\",\n    \"start\": \"node dist/server.js\",\n    \"lint\": \"eslint src --max-warnings 0\",\n    \"format\": \"prettier --write \\\"src/**/*.{ts,tsx}\\\"\",\n    \"type-check\": \"tsc --noEmit\",\n    \"test\": \"jest\",\n    \"test:watch\": \"jest --watch\",\n    \"migrate\": \"ts-node src/database/migrate.ts\",\n    \"migrate:rollback\": \"ts-node src/database/rollback.ts\",\n    \"migrate:create\": \"ts-node src/database/create-migration.ts\",\n    \"seed\": \"ts-node src/database/seed.ts\",\n    \"docs:generate\": \"swagger-jsdoc -d swaggerDef.js -f \\\"src/routes/**/*.ts\\\" -o src/swagger.json\"\n  },\n  \"dependencies\": {\n    \"express\": \"^4.18.0\",\n    \"helmet\": \"^7.0.0\",\n    \"cors\": \"^2.8.5\",\n    \"express-rate-limit\": \"^7.0.0\",\n    \"pg\": \"^8.11.0\",\n    \"dotenv\": \"^16.3.0\",\n    \"jsonwebtoken\": \"^9.1.0\",\n    \"bcryptjs\": \"^2.4.3\",\n    \"axios\": \"^1.5.0\",\n    \"winston\": \"^3.10.0\",\n    \"joi\": \"^17.10.0\",\n    \"express-validator\": \"^7.0.0\",\n    \"uuid\": \"^9.0.0\",\n    \"date-fns\": \"^2.30.0\"\n  },\n  \"devDependencies\": {\n    \"typescript\": \"^5.2.0\",\n    \"@types/node\": \"^20.5.0\",\n    \"@types/express\": \"^4.17.0\",\n    \"@types/cors\": \"^2.8.0\",\n    \"@types/jsonwebtoken\": \"^9.0.0\",\n    \"@types/bcryptjs\": \"^2.4.0\",\n    \"@types/jest\": \"^29.5.0\",\n    \"ts-node\": \"^10.9.0\",\n    \"nodemon\": \"^3.0.0\",\n    \"eslint\": \"^8.49.0\",\n    \"@typescript-eslint/eslint-plugin\": \"^6.5.0\",\n    \"@typescript-eslint/parser\": \"^6.5.0\",\n    \"prettier\": \"^3.0.0\",\n    \"jest\": \"^29.7.0\",\n    \"ts-jest\": \"^29.1.0\",\n    \"supertest\": \"^6.3.0\",\n    \"